generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(cuid())
  name              String
  email             String            @unique
  password          String?
  role              Role              @default(EMPLOYEE)
  weeklyHours       Decimal?          @db.Decimal(5, 2)
  contractType      ContractType      @default(PERMANENT)
  contractHours     Decimal?          @db.Decimal(5, 2)
  contractStart     DateTime?         @db.Date
  contractEnd       DateTime?         @db.Date
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  timeEntries       TimeEntry[]
  kmEntries         KmEntry[]
  expenses          Expense[]
  vacationBudgets   VacationBudget[]
  absenceRequests   AbsenceRequest[] @relation("AbsenceRequests")
  absenceReviews    AbsenceRequest[] @relation("AbsenceReviewer")
}

enum Role {
  ADMIN
  FINANCE
  EMPLOYEE
}

enum ContractType {
  PERMANENT
  FIXED_TERM
  ZERO_HOURS
}

model Customer {
  id         String    @id @default(cuid())
  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  postalCode String?
  country    String?
  vatNumber  String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  projects   Project[]
  invoices   Invoice[]
  quotes     Quote[]
}

model Project {
  id                String                @id @default(cuid())
  customerId        String?
  customer          Customer?             @relation(fields: [customerId], references: [id])
  name              String
  description       String?
  status            ProjectStatus         @default(ACTIVE)
  defaultHourlyRate Decimal?              @db.Decimal(10, 2)
  defaultKmRate     Decimal?              @db.Decimal(10, 2)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  timeEntries       TimeEntry[]
  kmEntries         KmEntry[]
  activityRates     ProjectActivityRate[]
  activityLinks     ActivityTypeProject[]
  expenses          Expense[]
  tags              Tag[]
}

enum ProjectStatus {
  CONCEPT
  ACTIVE
  INACTIVE
  COMPLETED
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  projects  Project[]
}

model ActivityType {
  id                String                @id @default(cuid())
  name              String                @unique
  defaultRate       Decimal?              @db.Decimal(10, 2)
  billable          Boolean               @default(true)
  showInAllProjects Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  timeEntries       TimeEntry[]
  kmEntries         KmEntry[]
  projectRates      ProjectActivityRate[]
  projects          ActivityTypeProject[]
}

model ActivityTypeProject {
  activityTypeId String
  activityType   ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([activityTypeId, projectId])
}

model ProjectActivityRate {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activityTypeId String
  activityType   ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  rate           Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())

  @@unique([projectId, activityTypeId])
}

model TimeEntry {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id])
  activityTypeId String?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id])
  date           DateTime      @db.Date
  hours          Decimal       @db.Decimal(5, 2)
  description    String?
  rateOverride   Decimal?      @db.Decimal(10, 2)
  billable       Boolean       @default(true)
  invoiced       Boolean       @default(false)
  invoiceLineId  String?
  invoiceLine    InvoiceLine?  @relation(fields: [invoiceLineId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model KmEntry {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id])
  activityTypeId String?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id])
  date           DateTime      @db.Date
  km             Decimal       @db.Decimal(8, 2)
  description    String?
  rateOverride   Decimal?      @db.Decimal(10, 2)
  billable       Boolean       @default(true)
  invoiced       Boolean       @default(false)
  invoiceLineId  String?
  invoiceLine    InvoiceLine?  @relation(fields: [invoiceLineId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Invoice {
  id              String              @id @default(cuid())
  invoiceNumber   String              @unique
  customerId      String
  customer        Customer            @relation(fields: [customerId], references: [id])
  issueDate       DateTime            @db.Date
  dueDate         DateTime            @db.Date
  status          InvoiceStatus       @default(DRAFT)
  reference       String?
  subject         String?
  notes           String?
  subtotal        Decimal             @db.Decimal(10, 2)
  vatRate         Decimal             @db.Decimal(5, 2) @default(21)
  vatAmount       Decimal             @db.Decimal(10, 2)
  total           Decimal             @db.Decimal(10, 2)
  viewToken       String              @unique @default(dbgenerated("gen_random_uuid()"))
  sentAt          DateTime?
  reminderSentAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  lines           InvoiceLine[]
  attachments     InvoiceAttachment[]
}

model InvoiceAttachment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  filename  String
  url       String
  size      Int
  createdAt DateTime @default(now())
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

model InvoiceLine {
  id          String      @id @default(cuid())
  invoiceId   String
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal     @db.Decimal(8, 2)
  unitPrice   Decimal     @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)
  lineType    LineType    @default(HOURS)
  createdAt   DateTime    @default(now())
  timeEntries TimeEntry[]
  kmEntries   KmEntry[]
  expenses    Expense[]
}

enum LineType {
  HOURS
  KM
  OTHER
  EXPENSE
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
}

model Expense {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  categoryId    String
  category      ExpenseCategory  @relation(fields: [categoryId], references: [id])
  projectId     String?
  project       Project?         @relation(fields: [projectId], references: [id])
  date          DateTime         @db.Date
  description   String?
  amount        Decimal          @db.Decimal(10, 2)
  vatRate       Decimal          @db.Decimal(5, 2) @default(21)
  receiptUrl    String?
  billable      Boolean          @default(true)
  reimbursable  Boolean          @default(false)
  invoiced      Boolean          @default(false)
  invoiceLineId String?
  invoiceLine   InvoiceLine?     @relation(fields: [invoiceLineId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model CompanySettings {
  id           String   @id @default(cuid())
  name         String
  email        String?
  phone        String?
  address      String?
  city         String?
  postalCode   String?
  country      String?
  vatNumber    String?
  kvkNumber    String?
  iban         String?
  logoUrl      String?
  reminderDays Int      @default(14)
  updatedAt    DateTime @updatedAt
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  CANCELLED
}

model Quote {
  id          String            @id @default(cuid())
  quoteNumber String            @unique
  customerId  String
  customer    Customer          @relation(fields: [customerId], references: [id])
  issueDate   DateTime          @db.Date
  validUntil  DateTime          @db.Date
  status      QuoteStatus       @default(DRAFT)
  reference   String?
  subject     String?
  notes       String?
  subtotal    Decimal           @db.Decimal(10, 2)
  vatRate     Decimal           @db.Decimal(5, 2) @default(21)
  vatAmount   Decimal           @db.Decimal(10, 2)
  total       Decimal           @db.Decimal(10, 2)
  viewToken   String            @unique @default(dbgenerated("gen_random_uuid()"))
  sentAt      DateTime?
  approvedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  lines       QuoteLine[]
  attachments QuoteAttachment[]
}

model QuoteLine {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(8, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
}

model QuoteAttachment {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  filename  String
  url       String
  size      Int
  createdAt DateTime @default(now())
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AbsenceType {
  VACATION
  SICK
  SPECIAL_LEAVE
  UNPAID_LEAVE
}

model VacationBudget {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  hours     Decimal  @db.Decimal(5, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year])
}

model AbsenceRequest {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation("AbsenceRequests", fields: [userId], references: [id], onDelete: Cascade)
  type        AbsenceType   @default(VACATION)
  startDate   DateTime      @db.Date
  endDate     DateTime      @db.Date
  hours       Decimal       @db.Decimal(5, 2)
  description String?
  status      AbsenceStatus @default(PENDING)
  reviewedBy  String?
  reviewer    User?         @relation("AbsenceReviewer", fields: [reviewedBy], references: [id])
  reviewedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
